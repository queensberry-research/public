set dotenv-load := true
set positional-arguments := true

# clean

clean:
  git clean -fdx
  uv sync

cli *args:
  name=$(yq -p toml -o json '.' pyproject.toml | jq -r '.project.scripts | keys[]? | select(test("-cli$"))')
  if [ -n "${name}" ]; then
    "${name}" "$@"
  else
    echo "Project has no '*-cli' executable"
  fi

release:
  docker buildx build \
    --build-arg DEBIAN_VERSION=$DEBIAN_VERSION \
    --build-arg PYTHON_VERSION=$PYTHON_VERSION \
    --build-arg PACKAGE_NAME=$PACKAGE_NAME \
    --file docker/Dockerfile \
    --push \
    --tag=$DOCKER_REGISTRY_URL:$DOCKER_REGISTRY_PORT/$PACKAGE_NAME:latest \
    --tag=$DOCKER_REGISTRY_URL:$DOCKER_REGISTRY_PORT/$PACKAGE_NAME:$PACKAGE_VERSION \
    --tag=$DOCKER_REGISTRY_URL:$DOCKER_REGISTRY_PORT/$PACKAGE_NAME:$PACKAGE_VERSION_MAJOR \
    --tag=$DOCKER_REGISTRY_URL:$DOCKER_REGISTRY_PORT/$PACKAGE_NAME:$PACKAGE_VERSION_MAJOR_MINOR \
    $@ .


registry *args:
  url='https://docker-registry.main:5000/v2'
  if [ $# -eq 0 ]; then
    curl -sS "$url/_catalog" | jq
  else
    curl -sS "$url/$1/tags/list" | jq
  fi

upw *args:
  docker compose --file docker/docker-compose.yml up --watch "$@"
