#!/usr/bin/env sh
# shellcheck disable=SC1090

# echo
echo_date() { echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" >&2; }

# local
source_env_if_exists '.envrc.local'

###############################################################################

# age
export AGE_RECIPIENT='age1wtv7d6qtzl43a6vgc0ahr3esk349t40szdyysu0cd84uvxm0e33sgksukd'

# python
export PYTHON_VERSION='3.13'

# docker
export DEBIAN_VERSION='trixie'
if ! PACKAGE_NAME=$(yq '.project.name' pyproject.toml); then
	echo_date "ERROR: failed to determine 'PACKAGE_NAME'" && exit 1
fi
export PACKAGE_NAME
if ! PACKAGE_VERSION=$(bump-my-version show current_version); then
	echo_date "ERROR: failed to determine 'PACKAGE_VERSION'" && exit 1
fi
export PACKAGE_VERSION
export DOCKER_REGISTRY_URL='docker-registry.test'
export DOCKER_REGISTRY_PORT='5000'

# pytest
export PY_COLORS='1'

# subnet
if [ -z "$SUBNET" ]; then
	echo_date "ERROR: 'SUBNET' is undefined" && exit 1
fi

# uv
export UV_MANAGED_PYTHON='true'
export UV_PRERELEASE='disallow'
if [ -z "$PYTHON_VERSION" ]; then
	echo_date "ERROR: 'PYTHON_VERSION' is undefined" && exit 1
fi
export UV_PYTHON="$PYTHON_VERSION"

if ! command -v uv >/dev/null 2>&1; then
	echo_date "ERROR: 'uv' not found" && exit 1
fi
activate='.venv/bin/activate'
if [ -f "$activate" ]; then
	. "$activate"
else
	uv venv
fi
uv sync --all-extras --all-groups --active --locked
